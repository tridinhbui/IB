generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String             @id @default(cuid())
  name               String?
  email              String?            @unique
  emailVerified      DateTime?
  image              String?
  password           String?
  accounts           Account[]
  sessions           Session[]
  userQuizProgresses UserQuizProgress[]
  quizAttempts       QuizAttempt[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EssayCategory {
  id        String          @id @default(cuid())
  name      String          @unique
  slug      String          @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  questions EssayQuestion[]
}

model EssayQuestion {
  id              String        @id @default(cuid())
  questionText    String
  suggestedAnswer String
  categoryId      String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  category        EssayCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
}

model QuizCategory {
  id                 String             @id @default(cuid())
  name               String             @unique
  slug               String             @unique
  createdAt          DateTime           @default(now())
  questions          QuizQuestion[]
  userQuizProgresses UserQuizProgress[]
}

model QuizQuestion {
  id            String       @id @default(cuid())
  questionId    String       @unique
  questionText  String
  choices       String[]
  correctAnswer String
  explanation   String
  difficulty    String       @default("Beginner")
  type          String       @default("mcq")
  categoryId    String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  category      QuizCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
}

model UserQuizProgress {
  id             String   @id @default(cuid())
  userId         String
  categoryId     String
  questionsDone  Int      @default(0)
  correctAnswers Int      @default(0)
  updatedAt      DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category QuizCategory @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId])
  @@index([userId])
}

model QuizAttempt {
  id         String   @id @default(cuid())
  userId     String
  section    String
  difficulty String
  score      Int
  total      Int
  accuracy   Int
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
